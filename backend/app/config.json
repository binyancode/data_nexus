{
    "is_root": true,
    "APP_NAME": "Data Nexus API",
    "APP_DESCRIPTION": "联邦语义中台 —— 一句话提问，跨源取数·归因·执行",
    "APP_VERSION": "0.1.0",
    "ALLOWED_ORIGINS": [
        "http://localhost:5173",
        "https://localhost:5173"
    ],
    "nexus": {
        "ontology": {
            "backend": "sqlite",
            "path": "nexus_ontology.db"
        },
        "llm": {
            "provider": "azure_openai",
            "endpoint": "",
            "api_key": "",
            "deployment": "gpt-4o",
            "api_version": "2024-06-01"
        }
    },
    "route_prefixes": {
        "api.v1.router": {
            "api_router": "api_router",
            "prefix": "/api/v1",
            "endpoints": {
                "ask.router": {
                    "prefix": "/ask",
                    "tags": ["Ask"]
                },
                "concepts.router": {
                    "prefix": "/concepts",
                    "tags": ["Ontology"]
                },
                "resolvers.router": {
                    "prefix": "/resolvers",
                    "tags": ["Resolvers"]
                }
            }
        }
    }
}
